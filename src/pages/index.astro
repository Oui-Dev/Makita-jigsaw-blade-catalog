---
import DocumentLayout from '@/layouts/DocumentLayout.astro';
import PrintPage from '@/components/layout/PrintPage.astro';
import SectionHead from '@/components/layout/SectionHead.astro';
import CoverPage from '@/components/cover/CoverPage.astro';
import LegendPage from '@/components/legend/LegendPage.astro';
import SummaryTable from '@/components/summary/SummaryTable.astro';
import BladeCard from '@/components/blade/BladeCard.astro';
import UsageIndexPage from '@/components/index/UsageIndexPage.astro';
import { documentPages } from '@/data/page-layout';
import { blades } from '@/data/blades';
---
<DocumentLayout>
  {documentPages.map((page) => {
    if (page.type === 'cover') {
      return (
        <PrintPage>
          <CoverPage />
        </PrintPage>
      );
    }
    if (page.type === 'legend') {
      return (
        <PrintPage>
          <LegendPage />
        </PrintPage>
      );
    }
    if (page.type === 'summary') {
      return (
        <PrintPage>
          <SummaryTable />
        </PrintPage>
      );
    }
    if (page.type === 'usage-index') {
      return (
        <PrintPage>
          <UsageIndexPage />
        </PrintPage>
      );
    }
    if (page.type === 'details') {
      return (
        <PrintPage>
          {page.pad && <div class="pad"></div>}
          {page.sectionHead && <SectionHead {...page.sectionHead} />}
          {page.blocks.map((block) => {
            const blade = blades[block.ref];
            return blade ? <BladeCard blade={blade} /> : null;
          })}
        </PrintPage>
      );
    }
    return null;
  })}
</DocumentLayout>
