---
import { ICON_SVGS } from '@/lib/icon-svgs';
import type { IconKey } from '@/types/catalog';

interface Props {
  name: IconKey;
  size?: number;
  class?: string;
}

const { name, size = 24, class: className = 'ico' } = Astro.props;
const inner = ICON_SVGS[name];
---
<svg
  class={className}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-hidden="true"
  set:html={inner}
/>
