---
import Icon from '@/components/icons/Icon.astro';
import { MATERIAL_LABELS } from '@/lib/constants';
import type { CutMaterialKey } from '@/types/catalog';

interface Props {
  materials: CutMaterialKey[];
}

const { materials } = Astro.props;
---

<div class="mat-row">
  {materials.map((key) => (
    <div class="mat-cell">
      <span class="mat-icon"><Icon name={key} size={22} /></span>
      <span class="mat-name">{MATERIAL_LABELS[key]}</span>
    </div>
  ))}
</div>
