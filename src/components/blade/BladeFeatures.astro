---
import type { BladeFeatures, IconKey } from '@/types/catalog';
import Icon from '@/components/icons/Icon.astro';

interface Props {
  features: BladeFeatures;
}

const { features } = Astro.props;

const items: { key: keyof BladeFeatures; icon: IconKey; label: string }[] = [
  { key: 'fast', icon: 'fast-cut', label: 'Rapide' },
  { key: 'clean', icon: 'clean-cut', label: 'Propre' },
  { key: 'curved', icon: 'curved-cut', label: 'Courbe' },
  { key: 'straight', icon: 'straight-cut', label: 'Droite' },
  { key: 'lubrication', icon: 'lubrication', label: 'Lubrif.' },
];
---
<div class="feats">
  {items.map((item) => (
    <div class={`feat ${features[item.key] ? 'on' : 'off'}`}>
      <div class="fic"><Icon name={item.icon} size={16} /></div>
      <div class="fl">{item.label}</div>
    </div>
  ))}
</div>
