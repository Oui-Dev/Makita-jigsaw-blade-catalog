---
import type { BladeFeatures } from '@/types/catalog';
import Icon from '@/components/icons/Icon.astro';

interface Props {
  features: BladeFeatures;
}

const { features } = Astro.props;

const items = [
  { key: 'rapide' as const, icon: 'coupe-rapide', label: 'Rapide' },
  { key: 'propre' as const, icon: 'coupe-propre', label: 'Propre' },
  { key: 'courbe' as const, icon: 'coupe-courbe', label: 'Courbe' },
  { key: 'droite' as const, icon: 'coupe-droite', label: 'Droite' },
  { key: 'lubrif' as const, icon: 'lubrification', label: 'Lubrif.' },
];
---
<div class="feats">
  {items.map((item) => (
    <div class={`feat ${features[item.key] ? 'on' : 'off'}`}>
      <div class="fic"><Icon name={item.icon} size={18} /></div>
      <div class="fl">{item.label}</div>
    </div>
  ))}
</div>
