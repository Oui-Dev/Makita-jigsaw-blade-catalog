---
import Icon from '@/components/icons/Icon.astro';
import Note from '@/components/layout/Note.astro';
import SectionHead from '@/components/layout/SectionHead.astro';
import { legendData } from '@/data/legend';
---

<SectionHead
  num="01"
  title="Légende des pictogrammes"
  desc="Symboles réutilisés à l'identique dans tout le document."
/>
{legendData.blocks.map((block) => (
  <div class="leg-block">
    <h3>{block.title}</h3>
    <div class={`leg-grid${block.twoCol ? ' two' : ''}`}>
      {block.items.map((item) => (
        <div class={`leg-item${item.kind === 'material' ? ' leg-mat' : ''}${item.kind === 'feature' ? ' leg-feat' : ''}`}>
          {item.kind === 'material' && (
            <>
              <span class="chip" style={`background:${item.color}`}>{item.code}</span>
              <div class="leg-text"><b>{item.label}</b><span>{item.desc}</span></div>
            </>
          )}
          {item.kind === 'tooth' && (
            <>
              <div class="tooth-row"><span class="code">{item.code}</span></div>
              <div class="leg-text"><b>{item.label}</b><span>{item.desc}</span></div>
            </>
          )}
          {(item.kind === 'feature' || item.kind === 'spec' || item.kind === 'cut-material') && (
            <>
              <span class="leg-icon"><Icon name={item.iconKey} size={24} /></span>
              <div class="leg-text">
                <b>{item.label}</b>
                {'desc' in item && item.desc && <span>{item.desc}</span>}
              </div>
            </>
          )}
        </div>
      ))}
    </div>
  </div>
))}

<Note html={legendData.noteHtml} />
