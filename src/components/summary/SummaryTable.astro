---
import SectionHead from '@/components/layout/SectionHead.astro';
import MatBadge from '@/components/shared/MatBadge.astro';
import SummaryCheck from '@/components/shared/SummaryCheck.astro';
import { bladeRefs, blades } from '@/data/blades';

const rows = Object.values(blades).map((blade) => blade.summary);
---

<SectionHead
  num="02"
  title="Tableau récapitulatif"
  desc={`${bladeRefs.length} références compatibles, vue d'ensemble.`}
/>
<table class="sum">
  <thead>
    <tr>
      <th>Ref</th>
      <th class="col-center">Lame</th>
      <th class="col-center">TPI</th>
      <th class="col-center">Longueur</th>
      <th>Principaux matériaux</th>
      <th class="col-center">Rapide</th>
      <th class="col-center">Propre</th>
      <th class="col-center">Courbe</th>
      <th class="col-center">Lubrif.</th>
    </tr>
  </thead>
  <tbody>
    {rows.map((row) => (
      <tr>
        <td class="blade-ref">{row.ref}</td>
        <td class="col-center"><MatBadge code={row.material} /></td>
        <td class="col-center">{row.tpi}</td>
        <td class="col-center">{row.length}</td>
        <td>{row.mainMaterials}</td>
        <td class="col-center"><SummaryCheck value={row.fast} /></td>
        <td class="col-center"><SummaryCheck value={row.clean} /></td>
        <td class="col-center"><SummaryCheck value={row.curved} /></td>
        <td class="col-center"><SummaryCheck value={row.lubrication} /></td>
      </tr>
    ))}
  </tbody>
</table>
