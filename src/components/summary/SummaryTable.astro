---
import { summaryRows, summaryNoteHtml } from '@/data/summary';
import MatBadge from '@/components/shared/MatBadge.astro';
import YesNo from '@/components/shared/YesNo.astro';
import Note from '@/components/layout/Note.astro';
---
<div class="pad"></div>
<div class="sec-head">
  <span class="num">02</span>
  <h2>Tableau recapitulatif</h2>
  <div class="desc">37 references compatibles, vue d'ensemble.</div>
</div>
<table class="sum">
  <thead>
    <tr>
      <th>Ref</th>
      <th class="c">Lame</th>
      <th class="c">TPI</th>
      <th class="c">Longueur</th>
      <th>Principaux materiaux</th>
      <th class="c">Rapide</th>
      <th class="c">Propre</th>
      <th class="c">Courbe</th>
      <th class="c">Lubrif.</th>
    </tr>
  </thead>
  <tbody>
    {summaryRows.map((row) => (
      <tr>
        <td class="ref">{row.ref}</td>
        <td class="c"><MatBadge code={row.material} /></td>
        <td class="c">{row.tpi}</td>
        <td class="c">{row.length}</td>
        <td>{row.mainMaterials}</td>
        <td class="c"><YesNo value={row.fast} /></td>
        <td class="c"><YesNo value={row.clean} /></td>
        <td class="c"><YesNo value={row.curved} /></td>
        <td class="c"><YesNo value={row.lubrication} /></td>
      </tr>
    ))}
  </tbody>
</table>
<Note html={summaryNoteHtml} />
