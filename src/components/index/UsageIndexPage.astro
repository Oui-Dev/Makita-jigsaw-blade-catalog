---
import Icon from '@/components/icons/Icon.astro';
import Note from '@/components/layout/Note.astro';
import SectionHead from '@/components/layout/SectionHead.astro';
import { usageIndex } from '@/data/usage-index';
---

<SectionHead
  num="04"
  title="Index par usage"
  desc="Retrouver rapidement les lames adaptées à chaque besoin."
/>
<div class="idx-grid">
  {usageIndex.entries.map((entry) => (
    <div class="idx-card">
      <div class="idx-header">
        <span class="ico"><Icon name={entry.iconKey} size={20} /></span>
        {entry.title}
        <span class="idx-count">{entry.refs.length} lame(s)</span>
      </div>
      <div class="idx-body">
        {entry.refs.map((ref) => (
          <span class="idx-chip">{ref}</span>
        ))}
      </div>
    </div>
  ))}
</div>
<Note html={usageIndex.noteHtml} />
<div class="foot-line">{usageIndex.footLine}</div>
