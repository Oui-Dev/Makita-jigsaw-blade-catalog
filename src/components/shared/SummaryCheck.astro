---
interface Props {
  value: boolean;
}

const { value } = Astro.props;
---
{value && (
  <svg
    class="sum-check"
    width="14"
    height="14"
    viewBox="0 0 24 24"
    xmlns="http://www.w3.org/2000/svg"
    role="img"
    aria-label="Oui"
  >
    <path
      d="M5 12l5 5L20 7"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
    />
  </svg>
)}
